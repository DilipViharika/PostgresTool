{
    "name": "@fathom/sdk",
    "version": "1.0.0",
    "description": "FATHOM SDK — Send API logs, errors, metrics, and audit events to your FATHOM dashboard",
    "main": "dist/index.js",
    "module": "src/index.js",
    "type": "module",
    "exports": {
        ".": {
            "import": "./src/index.js",
            "require": "./dist/index.cjs"
        }
    },
    "files": [
        "src/",
        "dist/",
        "README.md"
    ],
    "keywords": [
        "fathom",
        "monitoring",
        "observability",
        "api-monitoring",
        "error-tracking"
    ],
    "author": "FATHOM Team",
    "license": "MIT",
    "engines": {
        "node": ">=18.0.0"
    },
    "scripts": {
        "build": "node build.cjs",
        "test": "node --test tests/**/*.test.js"
    }
}
