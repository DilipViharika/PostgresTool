{
  "name": "@vigil/sdk",
  "version": "1.0.0",
  "description": "VIGIL SDK — Send API logs, errors, metrics, and audit events to your VIGIL dashboard",
  "main": "dist/index.js",
  "module": "src/index.js",
  "type": "module",
  "exports": {
    ".": {
      "import": "./src/index.js",
      "require": "./dist/index.cjs"
    }
