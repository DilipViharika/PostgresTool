{
    "name": "postgrestool-backend",
    "version": "1.0.0",
    "type": "module",
    "description": "FATHOM — Universal Database Monitoring & Administration Backend",
    "main": "server.js",
    "_note_optionalDependencies": "Phase-5 engine peer drivers. Each adapter in services/dbAdapters/ uses dynamic import() with graceful fallback, so these are OPTIONAL — npm install will still succeed on platforms where one of them can't build (e.g. oracledb needs the Oracle Instant Client). Only the drivers for engines you actually connect to need to be present at runtime.",
    "scripts": {
        "start": "node server.js",
        "dev": "nodemon server.js",
        "build": "tsc",
        "type-check": "tsc --noEmit",
        "test": "node --test tests/*.test.js tests/*.test.ts",
        "migrate": "node scripts/migrate.js",
        "migrate:enterprise": "node scripts/migrate-enterprise.js",
        "doctor": "node scripts/doctor.js"
    },
    "dependencies": {
        "@aws-sdk/client-cloudwatch": "^3.998.0",
        "@node-saml/node-saml": "^5.0.0",
        "bcryptjs": "^3.0.3",
        "cors": "^2.8.6",
        "dotenv": "^17.2.4",
        "drizzle-orm": "^0.45.1",
        "express": "^5.2.1",
        "helmet": "^8.0.0",
        "jsonwebtoken": "^9.0.3",
        "mongodb": "^6.12.0",
        "mysql2": "^3.11.0",
        "node-cron": "^4.2.1",
        "nodemailer": "^8.0.1",
        "pg": "^8.18.0",
        "uuid": "^13.0.0",
        "ws": "^8.19.0",
        "zod": "^3.24.0"
    },
    "optionalDependencies": {
        "mssql": "^11.0.1",
        "oracledb": "^6.6.0",
        "ioredis": "^5.4.2",
        "@elastic/elasticsearch": "^8.15.0",
        "snowflake-sdk": "^1.15.0",
        "@google-cloud/bigquery": "^7.9.0",
        "cassandra-driver": "^4.7.2",
        "@aws-sdk/client-dynamodb": "^3.998.0",
        "@aws-sdk/client-kms": "^3.998.0"
    },
    "devDependencies": {
        "@types/bcryptjs": "^2.4.6",
        "@types/cors": "^2.8.17",
        "@types/express": "^5.0.0",
        "@types/jsonwebtoken": "^9.0.7",
        "@types/node": "^22.10.0",
        "@types/node-cron": "^3.0.11",
        "@types/nodemailer": "^6.4.17",
        "@types/pg": "^8.11.10",
        "@types/uuid": "^10.0.0",
        "@types/ws": "^8.5.13",
        "drizzle-kit": "^0.31.10",
        "nodemon": "^3.1.11",
        "tsx": "^4.19.0",
        "typescript": "^5.7.0"
    }
}
