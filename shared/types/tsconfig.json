{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "lib": ["ES2022"],
        "strict": true,
        "declaration": true,
        "declarationMap": true,
        "outDir": "dist",
        "rootDir": ".",
        "esModuleInterop": true,
        "skipLibCheck": true,
        "noEmit": true
    },
    "include": ["*.ts"],
    "exclude": ["dist", "node_modules", "config.ts"]
}
