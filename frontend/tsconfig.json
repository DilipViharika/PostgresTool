{
    "compilerOptions": {
        /* ── Language & Output ─────────────────────────────────────────── */
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "lib": ["ES2022", "DOM", "DOM.Iterable"],
        "jsx": "react-jsx",

        /* ── Type Checking (incremental migration — tighten over time) ─── */
        "strict": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "strictNullChecks": false,
        "strictBindCallApply": true,
        "strictFunctionTypes": true,
        "noImplicitThis": true,
        "noImplicitAny": false,
        "noFallthroughCasesInSwitch": true,
        "forceConsistentCasingInFileNames": true,
        "allowJs": true,
        "checkJs": false,

        /* ── Module Interop ────────────────────────────────────────────── */
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "isolatedModules": true,
        "resolveJsonModule": true,

        /* ── Paths ─────────────────────────────────────────────────────── */
        "baseUrl": ".",
        "paths": {
            "@/*": ["src/*"],
            "@vigil/types": ["../shared/types/index.ts"],
            "@vigil/types/*": ["../shared/types/*"]
        },

        /* ── Output (Vite handles bundling — we only type-check) ───────── */
        "noEmit": true,
        "skipLibCheck": true
    },
    "include": [
        "src/**/*.ts",
        "src/**/*.tsx",
        "src/**/*.js",
        "src/**/*.jsx",
        "vite-env.d.ts",
        "../shared/types/**/*.ts"
    ],
    "exclude": ["node_modules", "dist"]
}