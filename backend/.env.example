# ─────────────────────────────────────────────────────────────────────────────
# FATHOM Backend — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── PostgreSQL Connection (REQUIRED) ─────────────────────────────────────────
PGHOST=localhost
PGPORT=5432
PGDATABASE=postgres
PGUSER=postgres
PGPASSWORD=your_password_here
# PGSSL=true

# ── JWT (REQUIRED in production — use a long random string) ──────────────────
JWT_SECRET=change-this-to-a-long-random-secret-in-production
JWT_EXPIRES_IN=8h

# ── Encryption Key (REQUIRED) ────────────────────────────────────────────────
# Used by services/encryptionService.js (AES-256-GCM via PBKDF2) to encrypt
# per-org integration secrets (Slack bot tokens, PagerDuty routing keys,
# Opsgenie keys, webhook HMAC shared secrets) and SAML SP private keys at
# rest. MUST be at least 32 characters of entropy and MUST NOT equal
# JWT_SECRET. Rotating this value invalidates every encrypted secret on disk.
# Generate with: `node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"`
ENCRYPTION_KEY=change-this-to-48-random-bytes-base64-encoded-and-never-reuse-jwt-secret

# ── Frontend URL (REQUIRED in production) ────────────────────────────────────
# Used for CORS and email links. Set to your Vercel frontend URL.
FRONTEND_URL=https://postgres-tool.vercel.app
# Additional CORS origin (optional, for extra allowed domains)
CORS_ORIGIN=

# ── Dashboard URL (used in email links) ──────────────────────────────────────
DASHBOARD_URL=https://postgres-tool.vercel.app

# ── Monitoring ───────────────────────────────────────────────────────────────
ALERT_MONITORING_INTERVAL=30000   # milliseconds (default: 30000)
SLOW_QUERY_MINUTES=5
RATE_LIMIT_MAX=300                # max requests per minute per IP

# ── Email Notifications (optional) ───────────────────────────────────────────
EMAIL_ENABLED=false
EMAIL_PROVIDER=smtp                # smtp | gmail | sendgrid | ses
EMAIL_FROM="FATHOM Alert System <alerts@yourdomain.com>"
EMAIL_RECIPIENTS=admin@yourdomain.com,ops@yourdomain.com
EMAIL_MIN_SEVERITY=warning         # info | warning | critical

# Gmail (EMAIL_PROVIDER=gmail)
# GMAIL_USER=you@gmail.com
# GMAIL_APP_PASSWORD=your_app_password

# SendGrid (EMAIL_PROVIDER=sendgrid)
# SENDGRID_API_KEY=SG.xxxxxxxxxxxx

# AWS SES (EMAIL_PROVIDER=ses)
# AWS_SES_REGION=us-east-1
# AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
# AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY

# Generic SMTP (EMAIL_PROVIDER=smtp)
# SMTP_HOST=smtp.yourdomain.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=smtp_user
# SMTP_PASSWORD=smtp_password
# SMTP_REJECT_UNAUTHORIZED=true

# ── Repository Browser ────────────────────────────────────────────────────────
# REPOSITORY_PATH=/path/to/your/repos

# ── Slack Bot API (two-way sync — replaces webhook-only approach) ─────────────
# Get these from https://api.slack.com/apps after creating your FATHOM bot app
SLACK_BOT_TOKEN=xoxb-your-bot-token-here          # OAuth Bot Token (never expose to frontend)
SLACK_SIGNING_SECRET=your-signing-secret-here      # From Basic Information page
SLACK_CHANNEL_ID=C0123456789                       # Target #alerts channel ID
# Legacy webhook (still supported as fallback if BOT_TOKEN is not set)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# ── Per-Organization Integration Fan-Out ──────────────────────────────────────
# FATHOM can dispatch each alert to every destination configured for the
# organization that owns it (Slack, PagerDuty, Opsgenie, Teams, signed
# webhook). Destinations are managed through /api/integrations and require
# ENCRYPTION_KEY (above) for at-rest secret encryption. No additional env
# vars are needed — everything is stored per-row in
# pgmonitoringtool.notification_destinations.
# See: backend/docs/INTEGRATIONS.md

# ── SAML SSO ──────────────────────────────────────────────────────────────────
# SAML is configured per workspace through the /api/saml/* endpoints — there
# are no SAML_* env vars to set here. Encrypted SP private keys are stored
# per-workspace in the database and protected by ENCRYPTION_KEY.

# ── Audit Log Export ──────────────────────────────────────────────────────────
# No env vars required. See: backend/docs/AUDIT_EXPORT.md for the streaming
# GET /api/audit/export endpoint (NDJSON or CSV, admin-only).
